---
# Adium code style:
#   - Tabs for indentation, 4-char tab width
#   - K&R brace for control flow, Allman for functions/methods
#   - Pointer * on the right (attached to variable name)
#   - 120 column limit
#   - ObjC @property: no space before parenthesis
#     (deliberate style change from the original codebase; the bulk format
#      commit applied this consistently across all owned source files)
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: ForContinuationAndIndentation
ColumnLimit: 120
PointerAlignment: Right
ObjCSpaceAfterProperty: false
ObjCBlockIndentWidth: 4
AllowShortIfStatementsOnASingleLine: Never
AllowShortFunctionsOnASingleLine: Inline
BreakBeforeBraces: Custom
BraceWrapping:
  AfterControlStatement: Never
  AfterFunction: true
  AfterClass: false
  AfterStruct: false
  AfterEnum: false
  BeforeElse: false
  BeforeCatch: false
  BeforeWhile: false
  SplitEmptyFunction: false
  SplitEmptyRecord: false
...
